{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/bracelets/layout,_N_T_/bracelets/page,_N_T_/bracelets"
