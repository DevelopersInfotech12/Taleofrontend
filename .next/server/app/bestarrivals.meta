{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/bestarrivals/layout,_N_T_/bestarrivals/page,_N_T_/bestarrivals"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/bestarrivals/__PAGE__",
    "/bestarrivals",
    "/_index",
    "/_head"
  ]
}